          <div class="h-[46.88rem] w-[75.63rem]">
            <h3 class="text-blue-900 text-4xl font-semibold h-11 leading-[2.75rem] mb-8 w-[75.63rem]">River Cruises &amp; Combo Tickets</h3>
            <div class="text-zinc-500 text-2xl h-9 leading-[2.13rem] mb-5 -ml-3.5 -mr-3.5 -mt-7 w-[77.50rem]">
              <div class="h-9 max-w-[77.50rem] px-4 w-full m-auto min-[576px]:max-w-[33.75rem] md:max-w-[45.00rem] min-[992px]:max-w-[60.00rem] min-[1200px]:max-w-[71.25rem]"><p class="h-9 mb-4 w-[75.63rem]">Select the Best Cruise for you!</p></div>
